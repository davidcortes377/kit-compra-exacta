<!-- BLOQUE 11: Preguntas frecuentes -->
<div class="ce-shopify-block" data-root style="--accent:#ffd84a;--green:#18c964;--green2:#0aa650;--red:#ff3d4e;--muted:#a9b3c9;--mono:'Montserrat',Arial,sans-serif;color:#f8fafc;background:#050713;font-family:'Montserrat',Arial,sans-serif;position:relative;overflow:hidden;">
  <section id="faq" style="padding:76px 0;text-align:center;;font-family:'Montserrat',Arial,sans-serif">
<div style="width:min(1120px,calc(100% - 32px));margin:0 auto;;font-family:'Montserrat',Arial,sans-serif">
